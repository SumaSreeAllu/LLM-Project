{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Title of the conversation"
    },
    "messages": {
      "type": "array",
      "description": "Array of message objects in the conversation",
      "items": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "user",
              "assistant"
            ]
          },
          "content": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "description": "Confidence score 0-100 for assistant replies"
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "timestamp": {
            "type": "string"
          }
        }
      }
    }
  },
  "required": [
    "title"
  ]
}
